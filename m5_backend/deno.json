{
  "tasks": {
    "start": "supabase start",
    "stop": "supabase stop",
    "reset": "supabase db reset",
    "functions-deploy": "supabase functions deploy",
    "functions-logs": "supabase functions logs"
  },
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.unstable"
